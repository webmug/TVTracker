# --- Database (Railway PostgreSQL plugin geeft deze automatisch) ---
DATABASE_URL="postgresql://user:password@localhost:5432/tvtracker?schema=public"

# --- Auth.js ---
# Genereer met: openssl rand -base64 32
AUTH_SECRET="change-me"
# Publieke URL van de app (lokaal: http://localhost:3000)
NEXTAUTH_URL="http://localhost:3000"

# --- TMDB (gratis: themoviedb.org -> Settings -> API) ---
# Gebruik de v3 API Key (of v4 Read Access Token in TMDB_BEARER)
TMDB_API_KEY=""
# Dev-only: zet op "1" om zonder geldige TMDB-key met mock-data te werken
# (trending/aanbevelingen/status op Verken). Laat leeg/0 in productie.
TMDB_MOCK=""

# --- Resend (e-mail voor login-links + meldingen) ---
RESEND_API_KEY=""
# Afzender. Voor test kun je 'onboarding@resend.dev' gebruiken (alleen naar eigen adres).
EMAIL_FROM="TV Tracker <onboarding@resend.dev>"

# --- App ---
# Komma-gescheiden lijst van e-mailadressen die admin worden bij eerste login.
ADMIN_EMAILS="jij@voorbeeld.nl"

# --- Cron (nieuwe-aflevering meldingen) ---
# Geheime sleutel die het cron-endpoint beschermt. Genereer met: openssl rand -hex 24
CRON_SECRET=""
# Basis-URL van de app voor de cron-trigger (mag gelijk zijn aan NEXTAUTH_URL).
APP_URL="http://localhost:3000"
