generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth.js models (magic-link / email provider)
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(MEMBER)
  createdAt     DateTime  @default(now())

  // E-mailvoorkeuren (opt-out): standaard aan voor bestaande en nieuwe gebruikers.
  dailyEmails   Boolean   @default(true) // dagelijkse nieuwe-afleveringen-mail
  weeklyDigest  Boolean   @default(true) // wekelijkse vrijdag-samenvatting

  accounts        Account[]
  sessions        Session[]
  follows         Follow[]
  watchedEpisodes WatchedEpisode[]
  watchedMovies   WatchedMovie[]
  watchlistMovies WatchlistMovie[]
  invitesSent     Invite[]         @relation("InvitedBy")
}

enum Role {
  ADMIN
  MEMBER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Invite-only access
// ---------------------------------------------------------------------------

model Invite {
  id        String    @id @default(cuid())
  email     String    @unique
  token     String    @unique
  invitedBy String?
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  inviter User? @relation("InvitedBy", fields: [invitedBy], references: [id], onDelete: SetNull)
}

// ---------------------------------------------------------------------------
// TV domain
// ---------------------------------------------------------------------------

model Show {
  id           String    @id @default(cuid())
  tmdbId       Int       @unique
  imdbId       String? // IMDb-id (bv. "tt1234567") voor externe link
  name         String
  overview     String?
  posterPath   String?
  status       String? // "Returning Series", "Ended", "Canceled", ...
  firstAirDate DateTime?
  lastSyncedAt DateTime  @default(now())

  episodes       Episode[]
  follows        Follow[]
  watchProviders ShowWatchProvider[]
}

// Cache van TMDB's watch/providers (via JustWatch, regio NL) per serie, zodat de
// bibliotheek op streamingdienst kan filteren zonder bij elke paginalading TMDB
// te bevragen. Wordt bijgewerkt in syncShow(), net als de andere TMDB-velden.
model ShowWatchProvider {
  id           String  @id @default(cuid())
  showId       String
  providerId   Int
  providerName String
  logoPath     String?

  show Show @relation(fields: [showId], references: [id], onDelete: Cascade)

  @@unique([showId, providerId])
  @@index([providerId])
}

model Episode {
  id       String    @id @default(cuid())
  showId   String
  tmdbId   Int? // TMDB episode id (kan ontbreken)
  season   Int
  number   Int
  name     String?
  overview String?
  airDate  DateTime?

  show    Show             @relation(fields: [showId], references: [id], onDelete: Cascade)
  watched WatchedEpisode[]

  @@unique([showId, season, number])
  @@index([airDate])
}

model Follow {
  id        String       @id @default(cuid())
  userId    String
  showId    String
  status    FollowStatus @default(WATCHING)
  createdAt DateTime     @default(now())
  // Cursor voor meldingen: hoogste air-datum die al is "gezien" door de cron.
  notifiedThroughDate DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  show Show @relation(fields: [showId], references: [id], onDelete: Cascade)

  @@unique([userId, showId])
  // Voor relatie-lookups vanaf de Show-kant (`follows: { some: {} }`).
  @@index([showId])
}

enum FollowStatus {
  WATCHING
  PAUSED
  FINISHED
}

model WatchedEpisode {
  id        String   @id @default(cuid())
  userId    String
  episodeId String
  watchedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@index([userId])
  // Voor de `watched: { none/some: { userId } }`-subquery, die op episodeId correleert.
  @@index([episodeId])
}

// ---------------------------------------------------------------------------
// Films (licht: alleen een "gezien"-logboek, geen seizoenen/afleveringen/meldingen)
// ---------------------------------------------------------------------------

model Movie {
  id           String    @id @default(cuid())
  tmdbId       Int       @unique
  imdbId       String? // IMDb-id (bv. "tt1234567") voor externe link
  title        String
  overview     String?
  posterPath   String?
  releaseDate  DateTime?
  lastSyncedAt DateTime  @default(now())

  watched        WatchedMovie[]
  watchlist      WatchlistMovie[]
  watchProviders MovieWatchProvider[]
}

// Zie ShowWatchProvider: dezelfde cache, maar voor films.
model MovieWatchProvider {
  id           String  @id @default(cuid())
  movieId      String
  providerId   Int
  providerName String
  logoPath     String?

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([movieId, providerId])
  @@index([providerId])
}

model WatchedMovie {
  id        String   @id @default(cuid())
  userId    String
  movieId   String
  watchedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([userId])
}

// Films die de gebruiker nog wil zien (TV Time's "towatch"). Losstaand van
// WatchedMovie: zodra een film gezien is, hoort hij daar thuis.
model WatchlistMovie {
  id      String   @id @default(cuid())
  userId  String
  movieId String
  addedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([userId])
}
